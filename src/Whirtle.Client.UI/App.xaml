<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Whirtle.Client.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="AccentButtonBackground"              Color="#5B2EFF" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver"   Color="#6E47FF" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPressed"       Color="#4A25CC" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
