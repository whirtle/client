<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Whirtle.Client.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <FontFamily x:Key="PlusJakartaSans">ms-appx:///Assets/Fonts/PlusJakartaSans-VariableFont_wght.ttf#Plus Jakarta Sans</FontFamily>
            <FontFamily x:Key="PlusJakartaSansItalic">ms-appx:///Assets/Fonts/PlusJakartaSans-Italic-VariableFont_wght.ttf#Plus Jakarta Sans</FontFamily>

            <SolidColorBrush x:Key="AccentButtonBackground"              Color="#5B2EFF" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver"   Color="#9B72FF" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPressed"       Color="#4A25CC" />
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#1C0D3E" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
