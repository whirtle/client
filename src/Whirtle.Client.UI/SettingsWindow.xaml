<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Whirtle.Client.UI.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="using:Whirtle.Client.UI.Pages"
    Title="Whirtle — Settings">

    <Grid Background="#1C0D3E">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapeKey" />
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Invisible drag strip replaces default title bar -->
        <Grid Grid.Row="0" x:Name="DragBar" />

        <pages:SettingsPage Grid.Row="1" x:Name="ContentPage" />
    </Grid>

</Window>
