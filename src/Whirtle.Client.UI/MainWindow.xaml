<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Whirtle.Client.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Whirtle.Client.UI"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:controls="using:Whirtle.Client.UI.Controls"
Title="Whirtle">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>

        <tb:TaskbarIcon
            Grid.RowSpan="2"
            x:Name="TrayIcon"
            ToolTipText="{x:Bind NowPlayingViewModel.TrayTooltip, Mode=OneWay}">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Show Whirtle" Click="TrayShow_Click" />
                    <MenuFlyoutItem x:Name="TrayMuteItem" Text="Mute" Click="TrayMute_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Quit Whirtle" Click="TrayQuit_Click" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <!-- Drag region / custom title bar -->
        <Grid Grid.Row="0" x:Name="AppTitleBar">
            <TextBlock
                Text="Whirtle"
                VerticalAlignment="Center"
                Margin="16,0"
                Style="{ThemeResource CaptionTextBlockStyle}" />
        </Grid>

        <!-- Player -->
        <Frame x:Name="ContentFrame" Grid.Row="1" />

        <!-- Status bar -->
        <Border
            Grid.Row="2"
            Padding="4,0,12,0"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Server picker button -->
                <Button
                    Grid.Column="0"
                    x:Name="ServerPickerButton"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="8,0"
                    CornerRadius="0"
                    Click="ServerPickerButton_Click">
                    <TextBlock
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind NowPlayingViewModel.ServerPickerLabel, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                </Button>

                <!-- Codec · sample rate -->
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind NowPlayingViewModel.CodecDisplay, Mode=OneWay}" />

                <!-- Signal bars -->
                <controls:SignalBarsControl
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Level="{x:Bind NowPlayingViewModel.SignalStrength, Mode=OneWay}" />

            </Grid>
        </Border>

    </Grid>
</Window>
