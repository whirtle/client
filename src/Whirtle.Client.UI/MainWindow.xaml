<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Whirtle.Client.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Whirtle.Client.UI"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:controls="using:Whirtle.Client.UI.Controls"
Title="Whirtle">

    <Grid KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="L" Modifiers="Control" Invoked="LogsAccelerator_Invoked" />
            <KeyboardAccelerator Key="S" Modifiers="Control" Invoked="StatsAccelerator_Invoked" />
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>

        <tb:TaskbarIcon
            Grid.RowSpan="2"
            x:Name="TrayIcon"
            ToolTipText="{x:Bind NowPlayingViewModel.TrayTooltip, Mode=OneWay}">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Show Whirtle" Click="TrayShow_Click" />
                    <MenuFlyoutItem x:Name="TrayMuteItem" Text="Mute" Click="TrayMute_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Quit Whirtle" Click="TrayQuit_Click" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <!-- Drag region / custom title bar -->
        <Grid Grid.Row="0" x:Name="AppTitleBar">
            <TextBlock
                Text="Whirtle"
                VerticalAlignment="Center"
                Margin="16,0"
                Style="{ThemeResource CaptionTextBlockStyle}" />
        </Grid>

        <!-- Player -->
        <Frame x:Name="ContentFrame" Grid.Row="1" />

        <!-- Status bar — hidden during FRE so no networking UI is shown -->
        <Border
            Grid.Row="2"
            Padding="4,0,12,0"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Visibility="{x:Bind StatusBarVisibility(UiStateService.CurrentState), Mode=OneWay}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Server picker button -->
                <Button
                    Grid.Column="0"
                    x:Name="ServerPickerButton"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="8,0"
                    CornerRadius="0"
                    Click="ServerPickerButton_Click">
                    <TextBlock
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind NowPlayingViewModel.ServerPickerLabel, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                </Button>

                <!-- Codec · sample rate -->
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind NowPlayingViewModel.CodecDisplay, Mode=OneWay}" />

                <!-- Signal bars -->
                <controls:SignalBarsControl
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Level="{x:Bind NowPlayingViewModel.SignalStrength, Mode=OneWay}" />

                <!-- Settings gear button -->
                <Button
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="4,2"
                    CornerRadius="4"
                    ToolTipService.ToolTip="Settings"
                    Click="SettingsButton_Click">
                    <FontIcon Glyph="&#xE713;" FontSize="13" />
                </Button>

            </Grid>
        </Border>

        <!-- ═══ FIRST-RUN SCRIM ════════════════════════════════════════════════
             Full-window overlay shown on first launch. Blocks all other UI.
             User must accept the license before proceeding.                    -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
            Visibility="{x:Bind FreScrimVisibility(UiStateService.CurrentState), Mode=OneWay}">

            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="28,24"
                MaxWidth="420">

                <StackPanel Spacing="20">

                    <TextBlock
                        Text="Welcome to Whirtle"
                        Style="{ThemeResource TitleTextBlockStyle}" />

                    <!-- License text -->
                    <ScrollViewer
                        MaxHeight="180"
                        VerticalScrollBarVisibility="Auto">
                        <RichTextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"
                            IsTextSelectionEnabled="True">
                            <Paragraph>
                                Whirtle is free software: you can redistribute it and/or
                                modify it under the terms of the GNU General Public License
                                as published by the Free Software Foundation, either version
                                3 of the License, or (at your option) any later version.
                            </Paragraph>
                            <Paragraph Margin="0,8,0,0">
                                This program is distributed in the hope that it will be
                                useful, but WITHOUT ANY WARRANTY; without even the implied
                                warranty of MERCHANTABILITY or FITNESS FOR A PARTICULAR
                                PURPOSE. See the GNU General Public License for more details.
                            </Paragraph>
                            <Paragraph Margin="0,8,0,0">
                                <Run>The full license is available at</Run><Run xml:space="preserve"> </Run><Hyperlink NavigateUri="https://github.com/whirtle/client/blob/main/LICENSE">https://github.com/whirtle/client/blob/main/LICENSE</Hyperlink><Run>.</Run>
                            </Paragraph>
                        </RichTextBlock>
                    </ScrollViewer>

                    <!-- Consent checkboxes -->
                    <StackPanel Spacing="8">
                        <CheckBox
                            x:Name="TermsCheckBox"
                            Content="I accept the license terms"
                            Checked="TermsCheckBox_Changed"
                            Unchecked="TermsCheckBox_Changed" />
                        <CheckBox
                            x:Name="TelemetryCheckBox"
                            Content="Help improve the reliability and performance of Whirtle by sending anonymous telemetry." />
                    </StackPanel>

                    <!-- Accept / Decline -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button
                            Content="Decline"
                            Click="FreDeclineButton_Click" />
                        <Button
                            x:Name="FreAcceptButton"
                            Content="Accept"
                            Style="{ThemeResource AccentButtonStyle}"
                            IsEnabled="False"
                            Click="FreAcceptButton_Click" />
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
