<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Whirtle.Client.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Whirtle.Client.UI"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:controls="using:Whirtle.Client.UI.Controls"
Title="Whirtle">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>

        <tb:TaskbarIcon
            Grid.RowSpan="2"
            x:Name="TrayIcon"
            ToolTipText="{x:Bind NowPlayingViewModel.TrayTooltip, Mode=OneWay}">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Show Whirtle" Click="TrayShow_Click" />
                    <MenuFlyoutItem x:Name="TrayMuteItem" Text="Mute" Click="TrayMute_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Quit Whirtle" Click="TrayQuit_Click" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <!-- Drag region / custom title bar -->
        <Grid Grid.Row="0" x:Name="AppTitleBar">
            <TextBlock
                Text="Whirtle"
                VerticalAlignment="Center"
                Margin="16,0"
                Style="{ThemeResource CaptionTextBlockStyle}" />
        </Grid>

        <!-- Player -->
        <Frame x:Name="ContentFrame" Grid.Row="1" />

        <!-- Status bar — hidden during FRE so no networking UI is shown -->
        <Border
            Grid.Row="2"
            Padding="4,0,12,0"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Visibility="{x:Bind StatusBarVisibility(UiStateService.CurrentState), Mode=OneWay}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Server picker button -->
                <Button
                    Grid.Column="0"
                    x:Name="ServerPickerButton"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="8,0"
                    CornerRadius="0"
                    Click="ServerPickerButton_Click">
                    <TextBlock
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind NowPlayingViewModel.ServerPickerLabel, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                </Button>

                <!-- Codec · sample rate -->
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind NowPlayingViewModel.CodecDisplay, Mode=OneWay}" />

                <!-- Signal bars -->
                <controls:SignalBarsControl
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Level="{x:Bind NowPlayingViewModel.SignalStrength, Mode=OneWay}" />

            </Grid>
        </Border>

        <!-- ═══ WAITING SCRIM ══════════════════════════════════════════════════
             Overlays the player when no session is active. Volume and mute are
             always enabled here. The Grid has no Background so pointer events
             outside the card pass through to NowPlayingPage beneath (e.g. the
             Settings and Logs buttons remain accessible).                      -->
        <Grid
            Grid.Row="1"
            Visibility="{x:Bind WaitingScrimVisibility(UiStateService.CurrentState), Mode=OneWay}">

            <!-- Dim layer — not hit-testable so clicks outside the card fall through -->
            <Rectangle Fill="#CC000000" IsHitTestVisible="False" />

            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="24,20"
                MinWidth="320"
                MaxWidth="400">

                <StackPanel Spacing="20">

                    <!-- Status indicator -->
                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                        <ProgressRing
                            IsActive="True"
                            Width="28" Height="28"
                            HorizontalAlignment="Center" />
                        <TextBlock
                            Text="{x:Bind NowPlayingViewModel.ConnectionStatus, Mode=OneWay}"
                            HorizontalAlignment="Center"
                            Style="{ThemeResource BodyTextBlockStyle}" />
                    </StackPanel>

                    <!-- Volume (always enabled in Waiting state) -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="0"
                            Padding="8"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="{x:Bind NowPlayingViewModel.MuteButtonTooltip, Mode=OneWay}"
                            Command="{x:Bind NowPlayingViewModel.ToggleMuteCommand}">
                            <FontIcon Glyph="{x:Bind NowPlayingViewModel.VolumeGlyph, Mode=OneWay}" FontSize="16" />
                        </Button>

                        <Slider
                            Grid.Column="1"
                            x:Name="WaitingVolumeSlider"
                            Minimum="0" Maximum="100"
                            Value="{x:Bind NowPlayingViewModel.VolumePercent, Mode=OneWay}"
                            VerticalAlignment="Center"
                            ValueChanged="WaitingVolumeSlider_ValueChanged" />

                        <TextBlock
                            Grid.Column="2"
                            Text="{x:Bind NowPlayingViewModel.VolumePercent, Mode=OneWay}"
                            VerticalAlignment="Center"
                            TextAlignment="Right"
                            Style="{ThemeResource CaptionTextBlockStyle}" />
                    </Grid>

                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ FIRST-RUN SCRIM ════════════════════════════════════════════════
             Full-window overlay shown on first launch. Blocks all other UI.
             User must accept the license before proceeding.                    -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
            Visibility="{x:Bind FreScrimVisibility(UiStateService.CurrentState), Mode=OneWay}">

            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="28,24"
                MaxWidth="420">

                <StackPanel Spacing="20">

                    <TextBlock
                        Text="Welcome to Whirtle"
                        Style="{ThemeResource TitleTextBlockStyle}" />

                    <!-- License text -->
                    <ScrollViewer
                        MaxHeight="180"
                        VerticalScrollBarVisibility="Auto">
                        <TextBlock
                            x:Name="LicenseTextBlock"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"
                            IsTextSelectionEnabled="True" />
                    </ScrollViewer>

                    <!-- Consent checkboxes -->
                    <StackPanel Spacing="8">
                        <CheckBox
                            x:Name="TermsCheckBox"
                            Content="I accept the license terms"
                            Checked="TermsCheckBox_Changed"
                            Unchecked="TermsCheckBox_Changed" />
                        <CheckBox
                            x:Name="TelemetryCheckBox"
                            Content="Send anonymous usage data to help improve Whirtle" />
                    </StackPanel>

                    <!-- Accept / Decline -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button
                            Content="Decline"
                            Click="FreDeclineButton_Click" />
                        <Button
                            x:Name="FreAcceptButton"
                            Content="Accept"
                            Style="{ThemeResource AccentButtonStyle}"
                            IsEnabled="False"
                            Click="FreAcceptButton_Click" />
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
