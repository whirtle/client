<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Whirtle.Client.UI.Pages.NowPlayingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Whirtle.Client.UI.Pages"
    xmlns:converters="using:Whirtle.Client.UI.Converters"
    Background="Transparent">

    <Page.Resources>
        <converters:SecondsToTimeConverter x:Key="SecondsToTime" />

        <Storyboard x:Name="LogoSpinStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="LogoRotate"
                Storyboard.TargetProperty="Angle"
                From="0" To="360"
                Duration="0:0:4"
                RepeatBehavior="Forever" />
        </Storyboard>

        <!-- Card appearance shared by every section -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"     Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush"    Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"   Value="8" />
            <Setter Property="Padding"        Value="20,16" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Loaded="Page_Loaded">
        <StackPanel
            Padding="10,24"
            Spacing="16">

            <!-- Invisible focus absorber: receives initial keyboard focus so no
                 interactive control appears highlighted when the page first loads. -->
            <Button
                x:Name="FocusSink"
                Width="0" Height="0"
                Opacity="0"
                Padding="0"
                BorderThickness="0"
                IsTabStop="True" />

            <!-- Artwork + Transport wrapped in a Grid so the waiting overlay
                 can dim just these two cards without covering Volume or the
                 Settings / Logs buttons below. -->
            <Grid>
                <StackPanel Spacing="16">

                    <!-- ═══ 1 · NOW PLAYING HEADER ═══════════════════════════ -->
                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Album art (rounded square, grey fill when no art) -->
                            <Border
                                Grid.Column="0"
                                Width="112" Height="112"
                                CornerRadius="8"
                                Background="#FF1A1040">
                                <Image
                                    x:Name="AlbumArtImage"
                                    Stretch="UniformToFill" />
                            </Border>

                            <!-- Track metadata -->
                            <StackPanel
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="6">
                                <TextBlock
                                    Text="{x:Bind ViewModel.Title, Mode=OneWay, FallbackValue='Nothing playing'}"
                                    FontFamily="{StaticResource PlusJakartaSans}"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Foreground="#F0ECFF"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="2" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.Artist, Mode=OneWay}"
                                    Style="{ThemeResource SubtitleTextBlockStyle}"
                                    FontFamily="{StaticResource PlusJakartaSans}"
                                    FontSize="13"
                                    FontWeight="Normal"
                                    Foreground="#B8AADD" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.Album, Mode=OneWay}"
                                    Style="{ThemeResource BodyTextBlockStyle}"
                                    FontFamily="{StaticResource PlusJakartaSans}"
                                    FontSize="13"
                                    FontWeight="Normal"
                                    Foreground="#B8AADD" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ═══ 2 · TRANSPORT ════════════════════════════════════ -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="12">

                            <!-- Playback buttons -->
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Center">

                                <!-- Previous -->
                                <Button
                                    Width="26" Height="26"
                                    Padding="0"
                                    CornerRadius="13"
                                    ToolTipService.ToolTip="Previous track"
                                    IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.PreviousCommand}">
                                    <FontIcon Glyph="&#xE892;" FontSize="10" />
                                </Button>

                                <!-- Play / Pause (accent-coloured circle) -->
                                <Button
                                    Width="34" Height="34"
                                    Padding="0"
                                    CornerRadius="17"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    ToolTipService.ToolTip="{x:Bind ViewModel.PlayPauseTooltip, Mode=OneWay}"
                                    IsEnabled="{x:Bind ViewModel.IsPlayEnabled, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.PlayPauseCommand}">
                                    <FontIcon
                                        Glyph="{x:Bind ViewModel.PlayPauseGlyph, Mode=OneWay}"
                                        FontSize="13" />
                                </Button>

                                <!-- Next -->
                                <Button
                                    Width="26" Height="26"
                                    Padding="0"
                                    CornerRadius="13"
                                    ToolTipService.ToolTip="Next track"
                                    IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.NextCommand}">
                                    <FontIcon Glyph="&#xE893;" FontSize="10" />
                                </Button>
                            </StackPanel>

                            <!-- Progress bar + time labels -->
                            <StackPanel Spacing="4">

                                <!--
                                    Seek bar — display only.  Maximum and Value are set in
                                    code-behind to avoid the WinUI 3 issue where x:Bind
                                    Mode=OneWay on Slider.Value is suppressed by the Slider's
                                    own internal value management.  IsHitTestVisible="False"
                                    and IsTabStop="False" make it non-interactive.
                                -->
                                <ProgressBar
                                    x:Name="SeekBar"
                                    Minimum="0"
                                    Foreground="#FF5B2EFF" />

                                <!-- [current time]                    [duration] -->
                                <Grid>
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        FontFamily="{StaticResource PlusJakartaSans}"
                                        FontSize="11"
                                        FontWeight="Normal"
                                        Foreground="#B8AADD"
                                        ToolTipService.ToolTip="Current position"
                                        Text="{x:Bind ViewModel.PositionSeconds,
                                                      Converter={StaticResource SecondsToTime},
                                                      Mode=OneWay}" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        FontFamily="{StaticResource PlusJakartaSans}"
                                        FontSize="11"
                                        FontWeight="Normal"
                                        Foreground="#B8AADD"
                                        ToolTipService.ToolTip="Track duration"
                                        Text="{x:Bind ViewModel.DurationSeconds,
                                                      Converter={StaticResource SecondsToTime},
                                                      Mode=OneWay}" />
                                </Grid>

                            </StackPanel>

                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ═══ WAITING OVERLAY ══════════════════════════════════════
                     Dims just the artwork and transport cards when no session
                     is active. Volume and the Settings / Logs buttons below
                     remain fully accessible.                                 -->
                <Grid Visibility="{x:Bind WaitingVisibility(ViewModel.IsNotConnected), Mode=OneWay}">
                    <Rectangle Fill="#CC000000" IsHitTestVisible="False" />
                    <Border
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#1A1040"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24,20"
                        MinWidth="220">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <Viewbox Width="28" Height="28" HorizontalAlignment="Center">
                                <Canvas Width="140" Height="140">
                                    <Canvas.RenderTransform>
                                        <RotateTransform x:Name="LogoRotate" CenterX="70" CenterY="70" />
                                    </Canvas.RenderTransform>
                                    <Path Fill="#5B2EFF" Data="M 70 70 C 62 50, 56 28, 62 16 C 65 10, 68 8, 70 8 C 72 8, 75 10, 78 16 C 84 28, 78 50, 70 70 Z" />
                                    <Path Fill="#FFB020" Data="M 70 70 C 88 76, 108 84, 118 100 C 122 107, 122 114, 120 117 C 117 120, 110 121, 104 119 C 88 113, 80 92, 70 70 Z" />
                                    <Path Fill="#FF5FA0" Data="M 70 70 C 52 76, 32 84, 22 100 C 18 107, 18 114, 20 117 C 23 120, 30 121, 36 119 C 52 113, 60 92, 70 70 Z" />
                                    <Ellipse Canvas.Left="57" Canvas.Top="57" Width="26" Height="26" Fill="#1A1040" />
                                    <Ellipse Canvas.Left="62" Canvas.Top="62" Width="16" Height="16" Fill="#FFFFFF" />
                                    <Ellipse Canvas.Left="66" Canvas.Top="66" Width="8"  Height="8"  Fill="#5B2EFF" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock
                                Text="{x:Bind ViewModel.ConnectionStatus, Mode=OneWay}"
                                HorizontalAlignment="Center"
                                Style="{ThemeResource BodyTextBlockStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>

            <!-- ═══ 3 · VOLUME ═══════════════════════════════════════════════ -->
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Mute toggle button -->
                    <Button
                        Grid.Column="0"
                        Padding="8"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="{x:Bind ViewModel.MuteButtonTooltip, Mode=OneWay}"
                        Command="{x:Bind ViewModel.ToggleMuteCommand}">
                        <FontIcon Glyph="{x:Bind ViewModel.VolumeGlyph, Mode=OneWay}" FontSize="16" />
                    </Button>

                    <!-- Volume slider (0 – 100) -->
                    <Slider
                        Grid.Column="1"
                        x:Name="VolumeSlider"
                        Minimum="0" Maximum="100"
                        Value="{x:Bind ViewModel.VolumePercent, Mode=OneWay}"
                        VerticalAlignment="Center"
                        ValueChanged="VolumeSlider_ValueChanged"
                        PointerCaptureLost="VolumeSlider_PointerCaptureLost">
                        <Slider.Resources>
                            <SolidColorBrush x:Key="SliderTrackValueFill" Color="#FF5B2EFF" />
                            <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="#FF5B2EFF" />
                            <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="#FF5B2EFF" />
                            <SolidColorBrush x:Key="SliderThumbBackground" Color="#FF9B72FF" />
                            <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="#FF9B72FF" />
                            <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="#FF9B72FF" />
                        </Slider.Resources>
                    </Slider>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
