<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Whirtle.Client.UI.Pages.NowPlayingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Whirtle.Client.UI.Pages"
    xmlns:converters="using:Whirtle.Client.UI.Converters"
    Background="Transparent">

    <Page.Resources>
        <converters:SecondsToTimeConverter x:Key="SecondsToTime" />

        <!-- Card appearance shared by every section -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"     Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush"    Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"   Value="8" />
            <Setter Property="Padding"        Value="20,16" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            Padding="24"
            Spacing="16"
            MaxWidth="860"
            HorizontalAlignment="Center">

            <!-- ═══ 1 · NOW PLAYING HEADER ═══════════════════════════════════ -->
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Album art (rounded square, accent colour fill when no art) -->
                    <Border
                        Grid.Column="0"
                        Width="112" Height="112"
                        CornerRadius="8"
                        Background="{ThemeResource SystemAccentColorDark1}">
                        <Image
                            x:Name="AlbumArtImage"
                            Stretch="UniformToFill" />
                    </Border>

                    <!-- Track metadata -->
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="6">
                        <TextBlock
                            Text="{x:Bind ViewModel.Title, Mode=OneWay, FallbackValue='Nothing playing'}"
                            Style="{ThemeResource TitleTextBlockStyle}"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="2" />
                        <TextBlock
                            Text="{x:Bind ViewModel.Artist, Mode=OneWay}"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.Album, Mode=OneWay}"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ 2 · TRANSPORT ════════════════════════════════════════════ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12" HorizontalAlignment="Center">

                    <!-- Time stamps flanking the seek bar -->
                    <Grid>
                        <TextBlock
                            HorizontalAlignment="Left"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.PositionSeconds,
                                          Converter={StaticResource SecondsToTime},
                                          Mode=OneWay}" />
                        <TextBlock
                            HorizontalAlignment="Right"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.DurationSeconds,
                                          Converter={StaticResource SecondsToTime},
                                          Mode=OneWay}" />
                    </Grid>

                    <!--
                        Seek bar — value is updated from the server; dragging sends a seek
                        command once the pointer is released.  The underlying protocol does
                        not yet define a seek message, so SeekCommand is a stub.
                    -->
                    <Slider
                        x:Name="SeekBar"
                        Minimum="0"
                        Maximum="{x:Bind ViewModel.DurationSeconds, Mode=OneWay}"
                        Value="{x:Bind ViewModel.PositionSeconds, Mode=OneWay}"
                        IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                        MinWidth="360"
                        PointerCaptureLost="SeekBar_PointerCaptureLost" />

                    <!-- Playback buttons -->
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Center">

                        <!-- Skip forward -->
                        <Button
                            Width="44" Height="44"
                            CornerRadius="22"
                            ToolTipService.ToolTip="Skip"
                            IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                            Command="{x:Bind ViewModel.SkipCommand}">
                            <FontIcon Glyph="&#xE893;" FontSize="16" />
                        </Button>

                        <!-- Play / Pause (accent-coloured circle) -->
                        <Button
                            Width="56" Height="56"
                            CornerRadius="28"
                            Style="{ThemeResource AccentButtonStyle}"
                            IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                            Command="{x:Bind ViewModel.PlayPauseCommand}">
                            <FontIcon
                                Glyph="{x:Bind ViewModel.PlayPauseGlyph, Mode=OneWay}"
                                FontSize="22" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══ 3 · VOLUME ═══════════════════════════════════════════════ -->
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>

                    <!-- Mute toggle button -->
                    <Button
                        Grid.Column="0"
                        Padding="8"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="{x:Bind ViewModel.MuteButtonTooltip, Mode=OneWay}"
                        Command="{x:Bind ViewModel.ToggleMuteCommand}">
                        <FontIcon Glyph="{x:Bind ViewModel.VolumeGlyph, Mode=OneWay}" FontSize="16" />
                    </Button>

                    <!-- Volume slider (0 – 100) -->
                    <Slider
                        Grid.Column="1"
                        x:Name="VolumeSlider"
                        Minimum="0" Maximum="100"
                        Value="{x:Bind ViewModel.VolumePercent, Mode=OneWay}"
                        IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                        VerticalAlignment="Center"
                        ValueChanged="VolumeSlider_ValueChanged" />

                    <!-- Numeric readout -->
                    <TextBlock
                        Grid.Column="2"
                        Text="{x:Bind ViewModel.VolumePercent, Mode=OneWay}"
                        VerticalAlignment="Center"
                        TextAlignment="Right"
                        Style="{ThemeResource CaptionTextBlockStyle}" />
                </Grid>
            </Border>

            <!-- ═══ 4 · SETTINGS BUTTON ════════════════════════════════════ -->
            <Button
                HorizontalAlignment="Left"
                Padding="12,8"
                Click="SettingsButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE713;" FontSize="16" VerticalAlignment="Center" />
                    <TextBlock Text="Settings" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

        </StackPanel>
    </ScrollViewer>
</Page>
