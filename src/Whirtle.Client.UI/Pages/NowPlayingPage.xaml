<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Whirtle.Client.UI.Pages.NowPlayingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Whirtle.Client.UI.Pages"
    xmlns:converters="using:Whirtle.Client.UI.Converters"
    Background="Transparent">

    <Page.Resources>
        <converters:SecondsToTimeConverter x:Key="SecondsToTime" />

        <!-- Card appearance shared by every section -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"     Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush"    Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"   Value="8" />
            <Setter Property="Padding"        Value="20,16" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Loaded="Page_Loaded">
        <StackPanel
            Padding="10,24"
            Spacing="16">

            <!-- Invisible focus absorber: receives initial keyboard focus so no
                 interactive control appears highlighted when the page first loads. -->
            <Button
                x:Name="FocusSink"
                Width="0" Height="0"
                Opacity="0"
                Padding="0"
                BorderThickness="0"
                IsTabStop="True" />

            <!-- Artwork + Transport wrapped in a Grid so the waiting overlay
                 can dim just these two cards without covering Volume or the
                 Settings / Logs buttons below. -->
            <Grid>
                <StackPanel Spacing="16">

                    <!-- ═══ 1 · NOW PLAYING HEADER ═══════════════════════════ -->
                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Album art (rounded square, accent colour fill when no art) -->
                            <Border
                                Grid.Column="0"
                                Width="112" Height="112"
                                CornerRadius="8"
                                Background="{ThemeResource SystemAccentColorDark1}">
                                <Image
                                    x:Name="AlbumArtImage"
                                    Stretch="UniformToFill" />
                            </Border>

                            <!-- Track metadata -->
                            <StackPanel
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="6">
                                <TextBlock
                                    Text="{x:Bind ViewModel.Title, Mode=OneWay, FallbackValue='Nothing playing'}"
                                    Style="{ThemeResource TitleTextBlockStyle}"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="2" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.Artist, Mode=OneWay}"
                                    Style="{ThemeResource SubtitleTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.Album, Mode=OneWay}"
                                    Style="{ThemeResource BodyTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ═══ 2 · TRANSPORT ════════════════════════════════════ -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="12">

                            <!-- Playback buttons -->
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Center">

                                <!-- Previous -->
                                <Button
                                    Width="26" Height="26"
                                    CornerRadius="13"
                                    ToolTipService.ToolTip="Previous track"
                                    IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.PreviousCommand}">
                                    <FontIcon Glyph="&#xE892;" FontSize="10" />
                                </Button>

                                <!-- Play / Pause (accent-coloured circle) -->
                                <Button
                                    Width="34" Height="34"
                                    CornerRadius="17"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    ToolTipService.ToolTip="{x:Bind ViewModel.PlayPauseTooltip, Mode=OneWay}"
                                    IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.PlayPauseCommand}">
                                    <FontIcon
                                        Glyph="{x:Bind ViewModel.PlayPauseGlyph, Mode=OneWay}"
                                        FontSize="13" />
                                </Button>

                                <!-- Next -->
                                <Button
                                    Width="26" Height="26"
                                    CornerRadius="13"
                                    ToolTipService.ToolTip="Next track"
                                    IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.NextCommand}">
                                    <FontIcon Glyph="&#xE893;" FontSize="10" />
                                </Button>
                            </StackPanel>

                            <!-- Position row: [current time] [seek bar] [duration] -->
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    ToolTipService.ToolTip="Current position"
                                    Text="{x:Bind ViewModel.PositionSeconds,
                                                  Converter={StaticResource SecondsToTime},
                                                  Mode=OneWay}" />

                                <!--
                                    Seek bar — display only.  Maximum and Value are set in
                                    code-behind to avoid the WinUI 3 issue where x:Bind
                                    Mode=OneWay on Slider.Value is suppressed by the Slider's
                                    own internal value management.  IsHitTestVisible="False"
                                    and IsTabStop="False" make it non-interactive.
                                -->
                                <Slider
                                    Grid.Column="1"
                                    x:Name="SeekBar"
                                    Minimum="0"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False"
                                    IsTabStop="False" />

                                <TextBlock
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    ToolTipService.ToolTip="Track duration"
                                    Text="{x:Bind ViewModel.DurationSeconds,
                                                  Converter={StaticResource SecondsToTime},
                                                  Mode=OneWay}" />
                            </Grid>

                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ═══ WAITING OVERLAY ══════════════════════════════════════
                     Dims just the artwork and transport cards when no session
                     is active. Volume and the Settings / Logs buttons below
                     remain fully accessible.                                 -->
                <Grid Visibility="{x:Bind WaitingVisibility(ViewModel.IsNotConnected), Mode=OneWay}">
                    <Rectangle Fill="#CC000000" IsHitTestVisible="False" />
                    <Border
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24,20"
                        MinWidth="220">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <ProgressRing
                                IsActive="True"
                                Width="28" Height="28"
                                HorizontalAlignment="Center" />
                            <TextBlock
                                Text="{x:Bind ViewModel.ConnectionStatus, Mode=OneWay}"
                                HorizontalAlignment="Center"
                                Style="{ThemeResource BodyTextBlockStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>

            <!-- ═══ 3 · VOLUME ═══════════════════════════════════════════════ -->
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Mute toggle button -->
                    <Button
                        Grid.Column="0"
                        Padding="8"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="{x:Bind ViewModel.MuteButtonTooltip, Mode=OneWay}"
                        Command="{x:Bind ViewModel.ToggleMuteCommand}">
                        <FontIcon Glyph="{x:Bind ViewModel.VolumeGlyph, Mode=OneWay}" FontSize="16" />
                    </Button>

                    <!-- Volume slider (0 – 100) -->
                    <Slider
                        Grid.Column="1"
                        x:Name="VolumeSlider"
                        Minimum="0" Maximum="100"
                        Value="{x:Bind ViewModel.VolumePercent, Mode=OneWay}"
                        VerticalAlignment="Center"
                        PointerCaptureLost="VolumeSlider_PointerCaptureLost" />
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
