<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Whirtle.Client.UI.Pages.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:logging="using:Whirtle.Client.UI.Logging"
    Background="Transparent">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Command="{x:Bind ViewModel.ClearCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Text="Clear" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button x:Name="CopySelectedButton" IsEnabled="False" Click="CopySelected_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8C8;" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Text="Copy Selected" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button Click="CopyAll_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8C8;" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Text="Copy All" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button Click="SaveToFile_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74E;" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Text="Save to File" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Log list -->
        <ListView
            x:Name="LogList"
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Entries}"
            SelectionMode="Extended"
            SelectionChanged="LogList_SelectionChanged"
>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="logging:LogEntry">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="90"  />
                            <ColumnDefinition Width="*"   />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Text="{x:Bind FormattedTimestamp}"
                            IsTextSelectionEnabled="True"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            FontFamily="Consolas"
                            VerticalAlignment="Center" />

                        <TextBlock
                            Grid.Column="1"
                            Text="{x:Bind Level}"
                            IsTextSelectionEnabled="True"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            FontFamily="Consolas"
                            VerticalAlignment="Center" />

                        <TextBlock
                            Grid.Column="2"
                            Text="{x:Bind Message}"
                            IsTextSelectionEnabled="True"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            FontFamily="Consolas"
                            TextWrapping="NoWrap"
                            TextTrimming="CharacterEllipsis"
                            VerticalAlignment="Center"
                            PointerEntered="OnMessagePointerEntered" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                    <Setter Property="Padding" Value="4,2" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</Page>
