<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Whirtle.Client.UI.Controls.SignalBarsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Four bottom-aligned bars of increasing height.
        Matches the 0–4 Level range: Level 1 = one bar lit, …, 4 = all four.
        Bar fill is updated from code-behind when the Level dependency property changes.
    -->
    <Grid Height="16">

        <StackPanel
            x:Name="BarsPanel"
            Orientation="Horizontal"
            Spacing="2"
            VerticalAlignment="Bottom">

            <Rectangle x:Name="Bar1" Width="3" Height="4"  VerticalAlignment="Bottom" RadiusX="1" RadiusY="1" />
            <Rectangle x:Name="Bar2" Width="3" Height="8"  VerticalAlignment="Bottom" RadiusX="1" RadiusY="1" />
            <Rectangle x:Name="Bar3" Width="3" Height="12" VerticalAlignment="Bottom" RadiusX="1" RadiusY="1" />
            <Rectangle x:Name="Bar4" Width="3" Height="16" VerticalAlignment="Bottom" RadiusX="1" RadiusY="1" />

        </StackPanel>

        <StackPanel
            x:Name="DotsPanel"
            Orientation="Horizontal"
            Spacing="2"
            VerticalAlignment="Bottom"
            Visibility="Collapsed">

            <Ellipse Width="3" Height="3" Fill="#9B72FF" />
            <Ellipse Width="3" Height="3" Fill="#9B72FF" />
            <Ellipse Width="3" Height="3" Fill="#9B72FF" />
            <Ellipse Width="3" Height="3" Fill="#9B72FF" />

        </StackPanel>

    </Grid>
</UserControl>
